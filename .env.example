# IaC Agent Environment Configuration
# Copy this file to .env and fill in your actual values

# =================================
# LLM Provider API Keys
# =================================

# OpenAI (GPT-4, GPT-3.5-turbo)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic (Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Azure OpenAI
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/

# Google (Gemini)
GOOGLE_API_KEY=your-google-api-key-here

# =================================
# Application Settings
# =================================

# Debug mode (true/false)
DEBUG=false

# Server host and port
HOST=127.0.0.1
PORT=8080

# Active LLM provider (openai, anthropic, azure_openai, google, ollama)
ACTIVE_LLM_PROVIDER=openai

# =================================
# Database Configuration
# =================================

# SQLite database file location
DATABASE__URL=sqlite:///./workspace.db
DATABASE__ECHO=false

# =================================
# Security Settings
# =================================

# Secret key for encryption (generate a secure random string)
SECURITY__SECRET_KEY=your-very-secure-secret-key-change-this-in-production

# Optional encryption key for sensitive data
SECURITY__ENCRYPTION_KEY=your-encryption-key-optional

# =================================
# Infrastructure Configuration
# =================================

# Workspace directory for Terraform files
INFRASTRUCTURE__WORKSPACE_DIRECTORY=./workspace

# Local binary installation directory
INFRASTRUCTURE__BIN_DIRECTORY=./bin

# Maximum resources to display in graph (performance limit)
INFRASTRUCTURE__MAX_RESOURCES=100

# Tool versions to install
INFRASTRUCTURE__TERRAFORM_VERSION=1.6.0
INFRASTRUCTURE__AZ_CLI_VERSION=2.55.0
INFRASTRUCTURE__AZTFEXPORT_VERSION=0.13.0

# =================================
# Azure Configuration (Optional)
# =================================

# Default Azure subscription ID
AZURE_SUBSCRIPTION_ID=your-subscription-id

# Default Azure tenant ID  
AZURE_TENANT_ID=your-tenant-id

# =================================
# Development Settings
# =================================

# Enable auto-reload in development
DEV_RELOAD=true

# Frontend development server URL
FRONTEND_DEV_URL=http://localhost:3000

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO